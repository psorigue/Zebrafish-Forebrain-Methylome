p <- ggplot(ds, aes(x = motif, y = meth, fill = strand)) +
geom_violin(
trim = TRUE,
alpha = 0.7,
position = position_dodge(width = 0.9)
) +
geom_boxplot(
width = 0.1,
outlier.shape = NA,
alpha = 0.5,
position = position_dodge(width = 0.9)
) +
labs(
